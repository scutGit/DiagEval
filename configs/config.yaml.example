# DiagEval LLM Configuration
# Copy this file to config.yaml and fill in your API credentials.
#
# The framework uses OpenAI-compatible API endpoints.
# Recommended models: claude-3-5-sonnet-v2, gpt-4o, gemini-2.0-flash

llm:
  api_type: openai
  model: "claude-3-5-sonnet-v2"
  base_url: "https://api.openai.com/v1"
  api_key: "${OPENAI_API_KEY}"    # Or set via environment variable
  stream: "false"
  max_token: 8192

case_generator:
  api_type: openai
  model: "claude-3-5-sonnet-v2"
  base_url: "https://api.openai.com/v1"
  api_key: "${OPENAI_API_KEY}"
  stream: "false"
  max_token: 8192

supervisor_judge:
  api_type: openai
  model: "claude-3-5-sonnet-v2"
  base_url: "https://api.openai.com/v1"
  api_key: "${OPENAI_API_KEY}"
  stream: "false"
  max_token: 8192

tell_verifier:
  api_type: openai
  model: "claude-3-5-sonnet-v2"
  base_url: "https://api.openai.com/v1"
  api_key: "${OPENAI_API_KEY}"
  stream: "false"
  max_token: 8192
